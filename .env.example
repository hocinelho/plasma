# Plasma environment variables — copy this file to .env and edit locally
# NEVER commit .env, only this .example file

# --- Local LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=orca-mini:latest

# --- Logging ---
PLASMA_LOG_LEVEL=INFO

# --- Cloud LLM (Groq — Step 9, optional: leave blank to stay local) ---
# Get a free key at https://console.groq.com
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.1-8b-instant   # fastest (~750 tok/s)
# GROQ_MODEL=llama-3.3-70b-versatile  # smartest

# --- Whisper model (speed vs accuracy tradeoff) ---
# WHISPER_MODEL=tiny.en    # ~1s, less accurate
# WHISPER_MODEL=base.en    # ~2s, good balance
# WHISPER_MODEL=small.en   # ~3-5s, default
# WHISPER_MODEL=medium.en  # ~8s, best for accents
