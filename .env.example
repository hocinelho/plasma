# Plasma environment variables — copy this file to .env and edit locally
# NEVER commit .env, only this .example file

# --- Local LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=orca-mini:latest

# --- Logging ---
PLASMA_LOG_LEVEL=INFO

# --- Cloud LLM (provider-agnostic OpenAI-compatible, optional) ---
# Leave CLOUD_API_KEY blank to stay fully local (Ollama only).
#
# Provider options (all speak the OpenAI wire protocol):
#
#   Google Gemini — free tier, 1500 req/day
#     CLOUD_API_KEY=your_google_ai_studio_key_here
#     CLOUD_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#     CLOUD_MODEL=gemini-2.0-flash
#
#   Cerebras — free tier, 60K tok/min
#     CLOUD_API_KEY=your_cerebras_key_here
#     CLOUD_BASE_URL=https://api.cerebras.ai/v1
#     CLOUD_MODEL=llama-3.3-70b
#
#   OpenRouter — free models available
#     CLOUD_API_KEY=your_openrouter_key_here
#     CLOUD_BASE_URL=https://openrouter.ai/api/v1
#     CLOUD_MODEL=meta-llama/llama-3.1-8b-instruct:free
#
#   Groq — was free, now paid
#     CLOUD_API_KEY=your_groq_key_here
#     CLOUD_BASE_URL=https://api.groq.com/openai/v1
#     CLOUD_MODEL=llama-3.1-8b-instant
#
CLOUD_API_KEY=
CLOUD_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
CLOUD_MODEL=gemini-2.0-flash

# --- Whisper model (speed vs accuracy tradeoff) ---
# WHISPER_MODEL=tiny.en    # ~1s, less accurate
# WHISPER_MODEL=base.en    # ~2s, good balance
# WHISPER_MODEL=small.en   # ~3-5s, default
# WHISPER_MODEL=medium.en  # ~8s, best for accents
